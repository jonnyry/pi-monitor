# pi_monitor.conf — copy to pi_monitor.conf and edit as needed.
# All settings are optional; the script works without this file using the defaults shown below.
# Command-line arguments always take precedence over values set here.

# Where to write the generated HTML file.
# OUTPUT_PATH = pi_monitor.html

# Host used for the internet connectivity ping check.
# PING_HOST = 8.8.8.8

# Number of ping packets to send.
# PING_COUNT = 4

# Set to true to enable the Tailscale status panel by default.
# Can also be enabled at runtime with --tailscale.
# TAILSCALE_ENABLED = false

# Docker container name to query when the native tailscale binary is not found.
# TAILSCALE_CONTAINER = tailscale
